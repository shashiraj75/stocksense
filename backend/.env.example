# No API keys required — this app runs 100% free
# All data comes from yfinance (free) and public RSS feeds

ENVIRONMENT=development

# Optional: Postgres (Supabase) persistence for the Learning Alpha Engine.
# Use the Supabase connection POOLER string (port 6543, sslmode=require) —
# get it from Supabase dashboard > Project Settings > Database > Connection Pooling.
# Leave both unset to keep using local SQLite (alpha_engine.db).
USE_POSTGRES=0
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require

# Secret for triggering daily pick generation (GitHub Actions cron)
PICKS_SECRET=change-me-in-production

# Required in production: verifies Supabase-issued JWTs on Portfolio/Watchlist/
# Alerts/Terms endpoints (Security Remediation Sprint #001 — fixes the Mini
# Security Audit's C-1 finding).
#
# SUPABASE_URL is required for current Supabase projects (JWT Signing Keys,
# ES256, the default since the JWT Signing Keys follow-up sprint) — same
# value as the frontend's NEXT_PUBLIC_SUPABASE_URL, used to build the JWKS
# endpoint (<SUPABASE_URL>/auth/v1/.well-known/jwks.json).
#
# SUPABASE_JWT_SECRET is only needed for projects still on the legacy shared
# HS256 secret (Project Settings > API > JWT Settings > JWT Secret) — leave
# unset if the project has migrated to JWT Signing Keys.
#
# Requests are rejected (fail-closed) if neither is configured for the
# algorithm a given token actually uses.
SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_JWT_SECRET=change-me-only-if-still-on-legacy-hs256-secret

# CORS: the production frontend origin(s). FRONTEND_URL is required for the
# deployed frontend to be allowed at all; STAGING_FRONTEND_URL is optional.
# Never set VERCEL_PREVIEW_ORIGIN_REGEX to a bare `.*\.vercel\.app` pattern —
# that was H-1 in the Mini Security Audit (a shared-domain wildcard combined
# with allow_credentials=True). If you need Vercel preview-deployment access,
# scope the regex to this project's own preview URL naming pattern only.
FRONTEND_URL=https://your-production-frontend.example.com
# STAGING_FRONTEND_URL=https://your-staging-frontend.example.com
# VERCEL_PREVIEW_ORIGIN_REGEX=https://your-project-name-[a-z0-9-]+\.vercel\.app

# Max stocks to include in daily picks universe.
# Leave unset to use all 98 Nifty 100 stocks.
# Set to 25 on memory-constrained hosts (e.g. Render free tier).
# PICKS_UNIVERSE_LIMIT=25

# Growth Intelligence Engine confidence-adjustment kill switch (Epic 003,
# Sprint #006's integration decision, implemented Sprint #007). Two
# independent switches, one per market — flipping either requires no code
# change. Defaults (used if left unset, exactly as shipped): India enabled,
# US disabled. The US switch exists for completeness/defense-in-depth, not
# because Sprint #006 authorizes enabling it — a future sprint's outcome
# re-validation (per Sprint #005's open finding) is required first.
# GROWTH_INTELLIGENCE_CONFIDENCE_ENABLED_IN=1
# GROWTH_INTELLIGENCE_CONFIDENCE_ENABLED_US=0
