# No API keys required — this app runs 100% free
# All data comes from yfinance (free) and public RSS feeds

ENVIRONMENT=development

# Optional: Postgres (Supabase) persistence for the Learning Alpha Engine.
# Use the Supabase connection POOLER string (port 6543, sslmode=require) —
# get it from Supabase dashboard > Project Settings > Database > Connection Pooling.
# Leave both unset to keep using local SQLite (alpha_engine.db).
USE_POSTGRES=0
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require
